{
  "version": 2,
  "status": "preregister-before-data-collection",
  "design": "two-period randomized counterbalanced within-participant crossover",
  "conditions": {
    "control": "uniform",
    "treatment": "section-adaptive"
  },
  "conditionCodes": {
    "uniform": "a",
    "section-adaptive": "b"
  },
  "alpha": 0.05,
  "targetPower": 0.8,
  "targetStandardizedPairedEffect": 0.35,
  "plannedCompletedParticipants": 72,
  "plannedRecruitment": 80,
  "randomization": {
    "seed": "cordalsur-section-theme-v1-2026-07-17",
    "blockSize": 4,
    "tasks": [
      "wifi",
      "checkin",
      "restaurant",
      "activity",
      "nearby",
      "weather",
      "tickets",
      "checkout",
      "emergency"
    ]
  },
  "primary": {
    "column": "visual_aesthetics",
    "label": "Perceived visual aesthetics composite",
    "range": [1, 7],
    "favorableDirection": "higher",
    "superiorityNull": 0,
    "smallestEffectOfInterest": 0.35,
    "smallestEffectUnit": "raw 1-7 scale points",
    "minimumCronbachAlpha": 0.7,
    "instrument": {
      "id": "visawi-s-es-working-translation-v1",
      "source": "Moshagen and Thielsch (2013), DOI 10.1080/0144929X.2012.694910",
      "language": "es-CL",
      "translationStatus": "pilot-required",
      "confirmatoryReady": false,
      "responseAnchors": ["Totalmente en desacuerdo", "Totalmente de acuerdo"],
      "items": [
        {
          "id": "coherence",
          "column": "aesthetics_coherence",
          "label": "Todos los elementos de esta guía combinan entre sí."
        },
        {
          "id": "variety",
          "column": "aesthetics_variety",
          "label": "El diseño de esta guía es agradablemente variado."
        },
        {
          "id": "color",
          "column": "aesthetics_color",
          "label": "La composición de colores de esta guía es atractiva."
        },
        {
          "id": "craftsmanship",
          "column": "aesthetics_craftsmanship",
          "label": "Esta guía parece diseñada profesionalmente."
        }
      ]
    }
  },
  "secondary": {
    "task_success_rate": {
      "range": [0, 1],
      "favorableDirection": "higher",
      "nonInferiorityLowerBound": -0.05
    },
    "error_count": {
      "range": [0, null],
      "favorableDirection": "lower",
      "nonInferiorityUpperBound": 0.25
    },
    "duration_seconds": {
      "range": [0, null],
      "favorableDirection": "lower",
      "multiplicityCorrection": "Holm"
    },
    "reuse_intention": {
      "range": [1, 7],
      "favorableDirection": "higher",
      "multiplicityCorrection": "Holm"
    }
  },
  "requiredSequences": [
    "uniform-section-adaptive",
    "section-adaptive-uniform"
  ],
  "allowedThemes": ["light", "dark"],
  "allowedDevices": ["mobile", "tablet", "desktop"],
  "exclusions": [
    "participant withdrawal",
    "documented technical failure that prevents task completion",
    "missing one of the two experimental conditions"
  ]
}
